# Modelmeter — environment variable template
#
# Copy this file to .env.local (gitignored) and fill in real values.
# Never commit a file with real secret values.
#
# Real-value storage by environment:
#   Local:      .env.local  OR  `export VAR=value` in your shell
#   CI:         GitHub repo Settings → Secrets and variables → Actions
#   Production: Cloudflare dashboard → Pages → modelmeter → Settings → Functions

# ---- Required for scripts/backfill.mjs (historical pricing crawl) ----

# Venice chat completions API key. Used by scripts/backfill.mjs to extract
# pricing tables from Wayback Machine HTML captures. Generate at:
#   https://venice.ai/  →  account  →  API keys
VENICE_API_KEY=

# Optional. Override the Venice model used for extraction.
# Default: qwen3-235b-a22b-instruct-2507
# Cheaper option: openai-gpt-oss-120b
# Higher accuracy: claude-sonnet-4-6 (more expensive)
VENICE_MODEL=

# ---- Future placeholders (not yet wired) ----

# OpenRouter referral code for "try this model" CTAs.
# Generate at: https://openrouter.ai/settings/integrations
# OPENROUTER_REFERRAL=

# Resend API key for outbound email (digest delivery, alerts).
# RESEND_API_KEY=

# Stripe keys for the paid API tier.
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=